# ─── MerchFlow AI — Backend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values before running.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL="postgresql://your_user@localhost:5432/merchflow?schema=public"
# Production (example):
# DATABASE_URL="postgresql://user:password@host:5432/merchflow?schema=public&connection_limit=5"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_USE_openssl_rand_base64_64"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development   # change to "production" on server

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:4000"

# ── AI — Google Gemini ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── AI — LightX (Virtual Try-On) ───────────────────────────────────────
# Get from: https://www.lightxeditor.com/
LIGHTX_API_URL="https://api.lightxeditor.com/external/api/v2/aivirtualtryon"
LIGHTX_API_KEY=""

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
# Or use Resend: SMTP_HOST=smtp.resend.com SMTP_USER=resend SMTP_PASS=your_api_key
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="MerchFlow AI <no-reply@merchflow.ai>"
