generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String         @id @default(uuid())
  email      String         @unique
  password   String
  name       String
  role       Role           @default(VIEWER)
  title      String?
  phone      String?
  avatarUrl  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  aiJobs     AIJob[]
  notes      CustomerNote[]
  imports    Import[]
  quotes     Quote[]

  @@map("users")
}

model Product {
  id             String          @id @default(uuid())
  sku            String          @unique
  name           String
  description    String?
  categoryId     String?
  collectionId   String?
  price          Decimal         @default(0) @db.Decimal(10, 2)
  cost           Decimal?        @db.Decimal(10, 2)
  stock          Int             @default(0)
  status         ProductStatus   @default(DRAFT)
  images         String[]
  tags           String[]
  aiAssets       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  aiJobs         AIJob[]
  inventoryItems InventoryItem[]
  category       Category?       @relation(fields: [categoryId], references: [id])
  collection     Collection?     @relation(fields: [collectionId], references: [id])
  quoteItems     QuoteItem[]

  @@map("products")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  status      String    @default("Active")
  aiEnabled   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Collection {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        String    @default("manual")
  layout      String    @default("grid")
  status      String    @default("Draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("collections")
}

model InventoryItem {
  id        String   @id @default(uuid())
  productId String
  location  String   @default("Main Hub")
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  incoming  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model Customer {
  id                   String             @id @default(uuid())
  name                 String
  company              String
  email                String             @unique
  phone                String?
  segment              String             @default("Wholesale Buyer")
  country              String             @default("US")
  region               String?
  source               String             @default("Import")
  status               CustomerStatus     @default(PROSPECT)
  assignedOwner        String?
  preferredOrderType   String?
  moqExpectations      String?
  preferredCategories  String[]
  preferredCollections String[]
  tags                 String[]
  archived             Boolean            @default(false)
  lifetimeValue        Decimal            @default(0) @db.Decimal(12, 2)
  ordersPlaced         Int                @default(0)
  lastActivityAt       DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  notes                CustomerNote[]
  reminders            CustomerReminder[]
  quotes               Quote[]

  @@map("customers")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  userId     String?
  body       String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@map("customer_notes")
}

model CustomerReminder {
  id         String   @id @default(uuid())
  customerId String
  body       String
  dueAt      DateTime
  done       Boolean  @default(false)
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_reminders")
}

model Quote {
  id            String         @id @default(cuid())
  customerId    String?
  buyerName     String
  buyerCompany  String
  buyerEmail    String
  buyerPhone    String?
  buyerCountry  String?
  source        String         @default("Sales")
  showroomId    String?
  currency      String         @default("USD")
  status        QuoteStatus    @default(DRAFT)
  expiryDate    DateTime?
  assignedToId  String?
  internalNotes String?
  archived      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  history       QuoteHistory[]
  items         QuoteItem[]
  assignedTo    User?          @relation(fields: [assignedToId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String?
  sku         String
  name        String
  qty         Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  discountPct Decimal  @default(0) @db.Decimal(5, 2)
  product     Product? @relation(fields: [productId], references: [id])
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model QuoteHistory {
  id      String   @id @default(uuid())
  quoteId String
  by      String
  action  String
  at      DateTime @default(now())
  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_history")
}

model Catalog {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("lookbook")
  template    String   @default("modern")
  source      String   @default("collection")
  audience    String   @default("b2b")
  status      String   @default("Draft")
  items       Json     @default("[]")
  sections    Json     @default("[]")
  toggles     Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("catalogs")
}

model Showroom {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  status      String   @default("Draft")
  coverImage  String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("showrooms")
}

model AIJob {
  id          String      @id @default(uuid())
  type        String      @default("try-on")
  status      AIJobStatus @default(QUEUED)
  progress    Int         @default(0)
  productId   String?
  garmentUrl  String?
  personUrl   String?
  outputs     Json        @default("[]")
  errorMsg    String?
  seed        Int?
  quality     String      @default("hd")
  variations  Int         @default(2)
  createdById String?
  createdAt   DateTime    @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  createdBy   User?       @relation(fields: [createdById], references: [id])
  product     Product?    @relation(fields: [productId], references: [id])

  @@map("ai_jobs")
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  tags      String[]
  createdAt DateTime @default(now())

  @@map("media")
}

model Import {
  id          String   @id @default(uuid())
  source      String
  fileName    String
  status      String   @default("Processing")
  totalRows   Int?
  successRows Int      @default(0)
  failedRows  Int      @default(0)
  errorLog    Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation(fields: [createdById], references: [id])

  @@map("imports")
}

enum Role {
  ADMIN
  MERCHANDISER
  SALES
  DESIGNER
  VIEWER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
  LOW_STOCK
}

enum CustomerStatus {
  ACTIVE
  PROSPECT
  INACTIVE
  ARCHIVED
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATING
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED_TO_ORDER
}

enum AIJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}
