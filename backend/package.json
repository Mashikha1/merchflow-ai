{
    "name": "merchflow-backend",
    "version": "1.0.0",
    "description": "MerchFlow AI – Real Backend (Express + PostgreSQL + Prisma)",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "dev": "node --watch src/index.js",
        "start": "node src/index.js",
        "db:push": "npx prisma db push",
        "db:migrate": "npx prisma migrate dev",
        "db:migrate:prod": "npx prisma migrate deploy",
        "db:studio": "npx prisma studio",
        "db:seed": "node prisma/seed.js",
        "db:reset": "npx prisma migrate reset --force && node prisma/seed.js"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@prisma/client": "5.22.0",
        "bcryptjs": "^2.4.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "csv-parse": "^6.2.1",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^8.4.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.2",
        "nodemailer": "^8.0.5",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "puppeteer": "^24.42.0",
        "sharp": "^0.34.5",
        "uuid": "^10.0.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "prisma": "5.22.0"
    }
}
